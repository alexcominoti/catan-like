{
  "name": "trevalis",
  "version": "0.1.0",
  "private": true,
  "description": "Jogo online de colonizacao hexagonal (inspirado em Catan) - local-first, vetorial, motor de regras puro.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @trevalis/web",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace @trevalis/web",
    "start": "npm start --workspace @trevalis/server",
    "server": "npm start --workspace @trevalis/server",
    "dev:server": "npm run dev --workspace @trevalis/server",
    "db:migrate": "npm run db:migrate --workspace @trevalis/db",
    "db:generate": "npm run db:generate --workspace @trevalis/db",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
