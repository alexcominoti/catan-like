# ------------------------------------------------------------------
# Trevalis — variaveis de ambiente (copie para .env e preencha).
# NUNCA comite o .env real. Em producao use `fly secrets set ...`.
# ------------------------------------------------------------------

# Porta do servidor unico (HTTP + WebSocket). Fly usa 8080.
PORT=8080

# Ambiente: development | production (cookies seguros so em production).
NODE_ENV=development

# URL publica do app (base para links de e-mail e cookies de sessao).
# Dev: http://localhost:8080  |  Prod: https://trevalis.app
APP_URL=http://localhost:8080

# Origens confiaveis para protecao CSRF / cookies (CSV). Inclua o front do dev.
# Dev (Vite faz proxy, mas registre por garantia):
WEB_ORIGIN=http://localhost:5173
# Prod: TRUSTED_ORIGINS=https://trevalis.app,https://www.trevalis.app
TRUSTED_ORIGINS=

# Segredo para assinar sessoes/cookies. Gere um forte:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   (ou: openssl rand -hex 32)
# Better Auth usa BETTER_AUTH_SECRET nativamente; SERVER_SECRET e o fallback.
# Pode definir os dois com o MESMO valor.
BETTER_AUTH_SECRET=
SERVER_SECRET=

# Dominio do cookie de sessao (apex + subdominios). Prod: .trevalis.app
# Em dev deixe vazio (localhost).
COOKIE_DOMAIN=

# --- Banco de dados (Postgres / Neon) ---
# String de conexao. Neon: postgresql://USER:PASS@HOST/db?sslmode=require
# Sem isto, o jogo (hotseat/bots) roda, mas /api/auth responde 503.
DATABASE_URL=
# Tamanho maximo do pool (opcional).
DB_POOL_MAX=10

# --- E-mail (Resend) ---
# Sem RESEND_API_KEY os links de confirmacao/reset sao apenas LOGADOS no console.
RESEND_API_KEY=
EMAIL_FROM=Trevalis <no-reply@trevalis.app>

# Exigir confirmacao de e-mail no cadastro (true em producao).
REQUIRE_EMAIL_VERIFICATION=false
